{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for sccsos metrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "title": "SCCS OS — 智能体运行时监控",
  "description": "SCCS Operating System — real-time monitoring dashboard for multi-agent runtime metrics",
  "tags": ["sccsos", "agent-runtime", "production"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Agent 总数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "rgba(245, 54, 54, 0.9)", "value": null },
              { "color": "rgba(237, 129, 40, 0.89)", "value": 0 },
              { "color": "rgba(50, 172, 45, 0.97)", "value": 100 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(sccsos_agent_info{status=~\"running|created|paused\"})",
          "legendFormat": "Agent 总数",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "运行中 Agent",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "rgba(245, 54, 54, 0.9)", "value": null },
              { "color": "rgba(237, 129, 40, 0.89)", "value": 0 },
              { "color": "rgba(50, 172, 45, 0.97)", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(sccsos_agent_info{status=\"running\"})",
          "legendFormat": "运行中",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "失败 Agent",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "rgba(245, 54, 54, 0.9)", "value": null },
              { "color": "rgba(245, 54, 54, 0.9)", "value": 0 },
              { "color": "rgba(237, 129, 40, 0.89)", "value": 1 },
              { "color": "rgba(50, 172, 45, 0.97)", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(sccsos_agent_info{status=\"failed\"})",
          "legendFormat": "失败",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "每小时 Token 消耗",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "legend": { "calcs": ["max", "mean", "last"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "barAlignment": 0,
            "fillOpacity": 20,
            "spanNulls": false,
            "pointSize": 3,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sccsos_token_total[5m])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "每小时成本 ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "legend": { "calcs": ["max", "mean", "last"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "USD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 3,
            "showPoints": "auto"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sccsos_cost_usd_total[5m])) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Agent 状态分布",
      "type": "bargauge",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "rgba(50, 172, 45, 0.97)", "value": null },
              { "color": "rgba(237, 129, 40, 0.89)", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "count(sccsos_agent_info) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "工作流执行状态 (近 1 小时)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "legend": { "calcs": ["max", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sccsos_workflow_runs_total[30m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "每分钟 API 调用量",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 2
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sccsos_api_requests_total[1m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "平均延迟 (ms) — 按模型",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "legend": { "calcs": ["max", "mean", "last"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 2
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "rate(sccsos_duration_ms_sum[5m]) / rate(sccsos_duration_ms_count[5m])",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "错误率 (%) — 按 Agent",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 2
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "rgba(50, 172, 45, 0.97)", "value": null },
              { "color": "rgba(237, 129, 40, 0.89)", "value": 5 },
              { "color": "rgba(245, 54, 54, 0.9)", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(sccsos_agent_errors_total[5m])) by (agent) / sum(rate(sccsos_agent_calls_total[5m])) by (agent) * 100",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ]
    }
  ]
}
