# SCCS OS — Slim Docker Image (standalone, no embedded Hermes Agent)
#
# Use when:
#   - Hermes Agent runs in a separate container (docker-exec adapter)
#   - Hermes Agent is accessed remotely (remote adapter)
#   - SCCS OS is used in headless/API-only mode without agent delegation
#
# Build:
#   docker build -t sccsos:0.16.0-slim -f Dockerfile.slim .
#
# Comparison with default Dockerfile:
#   + ~40-50% smaller image (no Hermes deps)
#   + Cleaner separation of concerns (Hermes lifecycle managed independently)
#   - Requires docker-exec or remote adapter for Hermes tasks
#   - Docker socket mount needed for docker-exec adapter

# Stage 1: Build wheel
FROM python:3.11-slim AS builder

WORKDIR /build
COPY . .
RUN pip install --no-cache-dir build && \
    python3 -m build --wheel && \
    echo "Build complete"

# Stage 2: Slim Runtime
FROM python:3.11-slim

LABEL org.sccsos.name="sccsos-slim" \
      org.sccsos.version="0.16.0" \
      org.sccsos.description="SCCS OS — Smart Agent Runtime Platform (slim, no embedded Hermes)"

# Only curl needed: health checks + RemoteHermesAdapter HTTP calls
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /sccsos

# Copy built wheel from builder
COPY --from=builder /build/dist/*.whl /tmp/

# Install SCCS OS with API extras (no hermes-agent)
RUN pip install --no-cache-dir /tmp/*.whl && \
    pip install --no-cache-dir "sccsos[api] @ file:///tmp/sccsos-0.16.0-py3-none-any.whl" && \
    rm /tmp/*.whl

# No Hermes Agent installed — HermesManager.discover() will:
#   1. Skip subprocess adapter (no hermes binary)
#   2. Fall back to docker-exec mode (if docker CLI + container available)
#   3. Fall back to remote adapter (if hermes.remote.url configured in sccsos.yaml)
#   4. Return clear diagnostic if neither is available

# Create default directories
RUN mkdir -p /sccsos/data /sccsos/logs /sccsos/traces \
             /sccsos/agents /sccsos/workflows /sccsos/personalities \
             /sccsos/config

# Copy default config
COPY sccsos.yaml /sccsos/sccsos.yaml
COPY personalities/ /sccsos/personalities/
COPY workflows/ /sccsos/workflows/

# Volume for persistent data
VOLUME ["/sccsos/data", "/sccsos/logs", "/sccsos/traces"]

# Expose API port
EXPOSE 8765

# Health check (curl-based, no hermes dependency)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -sf http://localhost:8765/health || exit 1

# Default: start API server
CMD ["python3", "-m", "sccsos", "serve", "--host", "0.0.0.0", "--port", "8765"]
